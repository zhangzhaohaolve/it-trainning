<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.training.modules.course.mapper.LearningRecordMapper">
    <select id="countByCourseId" resultType="java.lang.Integer">
        SELECT COUNT(1) FROM learning_record WHERE course_id = #{courseId} AND deleted = 0
    </select>
</mapper>
