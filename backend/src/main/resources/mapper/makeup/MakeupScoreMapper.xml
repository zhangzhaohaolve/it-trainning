<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.training.modules.makeup.mapper.MakeupScoreMapper">
    <resultMap id="SCMap" type="com.company.training.modules.makeup.entity.MakeupScore">
        <id property="id" column="id"/><result property="makeupId" column="makeup_id"/><result property="userId" column="user_id"/><result property="answers" column="answers"/><result property="score" column="score"/><result property="submitTime" column="submit_time"/><result property="status" column="status"/><result property="reviewer" column="reviewer"/><result property="reviewTime" column="review_time"/><result property="deleted" column="deleted"/>
    </resultMap>
    <insert id="insert" parameterType="com.company.training.modules.makeup.entity.MakeupScore" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO makeup_score(makeup_id,user_id,answers,score,submit_time,status,reviewer,review_time,deleted)
        VALUES(#{makeupId},#{userId},#{answers},#{score},NOW(),#{status},#{reviewer},#{reviewTime},0)
    </insert>
    <update id="updateReview" parameterType="com.company.training.modules.makeup.entity.MakeupScore">
        UPDATE makeup_score SET score=#{score},status=#{status},reviewer=#{reviewer},review_time=NOW() WHERE id=#{id} AND deleted=0
    </update>
    <select id="selectByMakeupAndUser" resultMap="SCMap">SELECT * FROM makeup_score WHERE makeup_id=#{makeupId} AND user_id=#{userId} AND deleted=0 LIMIT 1</select>
    <select id="selectPage" resultMap="SCMap">SELECT * FROM makeup_score WHERE deleted=0 <if test="makeupId!=null">AND makeup_id=#{makeupId}</if><if test="userId!=null">AND user_id=#{userId}</if> ORDER BY id DESC LIMIT #{offset()},#{pageSize}</select>
    <select id="countPage" resultType="java.lang.Long">SELECT COUNT(1) FROM makeup_score WHERE deleted=0 <if test="makeupId!=null">AND makeup_id=#{makeupId}</if><if test="userId!=null">AND user_id=#{userId}</if></select>
    <select id="selectOriginalScore" resultType="java.lang.Integer">SELECT score FROM exam_score WHERE exam_id=#{examId} AND user_id=#{userId} AND deleted=0 LIMIT 1</select>
</mapper>
