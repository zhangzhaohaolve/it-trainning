<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.training.modules.learning.mapper.LearningReminderMapper">
    <resultMap id="ReminderMap" type="com.company.training.modules.learning.entity.LearningReminder">
        <id property="id" column="id"/><result property="userId" column="user_id"/><result property="courseId" column="course_id"/>
        <result property="reminderType" column="reminder_type"/><result property="content" column="content"/>
        <result property="reminderTime" column="reminder_time"/><result property="status" column="status"/><result property="deleted" column="deleted"/>
    </resultMap>
    <insert id="insert" parameterType="com.company.training.modules.learning.entity.LearningReminder" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO learning_reminder(user_id,course_id,reminder_type,content,reminder_time,status,deleted)
        VALUES(#{userId},#{courseId},#{reminderType},#{content},NOW(),#{status},0)
    </insert>
    <update id="updateStatus">UPDATE learning_reminder SET status=#{status} WHERE id=#{id} AND deleted=0</update>
    <update id="logicDeleteById">UPDATE learning_reminder SET deleted=1 WHERE id=#{id} AND deleted=0</update>
    <select id="selectPage" resultMap="ReminderMap">
        SELECT * FROM learning_reminder WHERE deleted=0
        <if test="userId != null">AND user_id=#{userId}</if>
        <if test="reminderType != null">AND reminder_type=#{reminderType}</if>
        ORDER BY id DESC LIMIT #{offset()},#{pageSize}
    </select>
    <select id="countPage" resultType="java.lang.Long">
        SELECT COUNT(1) FROM learning_reminder WHERE deleted=0
        <if test="userId != null">AND user_id=#{userId}</if>
        <if test="reminderType != null">AND reminder_type=#{reminderType}</if>
    </select>
</mapper>
