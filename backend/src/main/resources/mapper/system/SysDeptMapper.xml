<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.training.modules.system.mapper.SysDeptMapper">
<resultMap id="DMap" type="com.company.training.modules.system.entity.SysDept"><id property="id" column="id"/><result property="name" column="name"/><result property="parentId" column="parent_id"/><result property="sort" column="sort"/><result property="createTime" column="create_time"/><result property="deleted" column="deleted"/></resultMap>
<insert id="insert" parameterType="com.company.training.modules.system.entity.SysDept" useGeneratedKeys="true" keyProperty="id">INSERT INTO sys_dept(name,parent_id,sort,create_time,deleted) VALUES(#{name},#{parentId},#{sort},NOW(),0)</insert>
<update id="updateById" parameterType="com.company.training.modules.system.entity.SysDept">UPDATE sys_dept SET name=#{name},parent_id=#{parentId},sort=#{sort} WHERE id=#{id} AND deleted=0</update>
<update id="logicDelete">UPDATE sys_dept SET deleted=1 WHERE id=#{id} AND deleted=0</update>
<select id="selectList" resultMap="DMap">SELECT * FROM sys_dept WHERE deleted=0 ORDER BY sort ASC,id ASC</select>
</mapper>
