<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.training.modules.system.mapper.SysLogMapper">
<insert id="insert" parameterType="com.company.training.modules.system.entity.SysLog">INSERT INTO sys_log(user_id,action,method,params,ip,create_time) VALUES(#{userId},#{action},#{method},#{params},#{ip},NOW())</insert>
<select id="selectList" resultType="com.company.training.modules.system.entity.SysLog">SELECT * FROM sys_log ORDER BY id DESC</select>
</mapper>
