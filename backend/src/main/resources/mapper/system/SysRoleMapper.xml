<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.training.modules.system.mapper.SysRoleMapper">
<resultMap id="RMap" type="com.company.training.modules.system.entity.SysRole"><id property="id" column="id"/><result property="name" column="name"/><result property="code" column="code"/><result property="remark" column="remark"/><result property="createTime" column="create_time"/><result property="deleted" column="deleted"/></resultMap>
<insert id="insert" parameterType="com.company.training.modules.system.entity.SysRole" useGeneratedKeys="true" keyProperty="id">INSERT INTO sys_role(name,code,remark,create_time,deleted) VALUES(#{name},#{code},#{remark},NOW(),0)</insert>
<update id="updateById" parameterType="com.company.training.modules.system.entity.SysRole">UPDATE sys_role SET name=#{name},code=#{code},remark=#{remark} WHERE id=#{id} AND deleted=0</update>
<update id="logicDelete">UPDATE sys_role SET deleted=1 WHERE id=#{id} AND deleted=0</update>
<select id="selectList" resultMap="RMap">SELECT * FROM sys_role WHERE deleted=0 ORDER BY id DESC</select>
<delete id="clearPermissions">DELETE FROM sys_role_permission WHERE role_id=#{roleId}</delete>
<insert id="bindPermissions">INSERT INTO sys_role_permission(role_id,permission_id) VALUES <foreach collection="permissionIds" item="pid" separator=",">(#{roleId},#{pid})</foreach></insert>
</mapper>
